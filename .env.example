# Backend
WEA_DATA_DIR=backend/app/data/demo
WEA_REAL_DATA_DIR=backend/app/data/real
WEA_DB_PATH=backend/app/data/investigations.sqlite
WEA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# STAC imagery search
# mock = use bundled synthetic STAC-like candidates
# auto = try real STAC first, fall back to bundled mock candidates if the network/query fails
# real = require real STAC search and surface errors
WEA_STAC_MODE=real
WEA_STAC_PROVIDER=earth-search
WEA_STAC_PROVIDER_ORDER=
WEA_STAC_API_URL=https://earth-search.aws.element84.com/v1
WEA_STAC_EARTH_SEARCH_API_URL=https://earth-search.aws.element84.com/v1
WEA_STAC_PLANETARY_COMPUTER_API_URL=https://planetarycomputer.microsoft.com/api/stac/v1
WEA_STAC_TIMEOUT_SECONDS=20
WEA_STAC_MAX_ITEMS=8

# Planetary Computer option for signed Azure Blob COG access, useful for Landsat C2 L2.
# WEA_STAC_PROVIDER=planetary-computer
# WEA_STAC_PROVIDER_ORDER=planetary-computer,earth-search
# WEA_STAC_API_URL=https://planetarycomputer.microsoft.com/api/stac/v1
WEA_PLANETARY_COMPUTER_SIGN_URL=https://planetarycomputer.microsoft.com/api/sas/v1/sign

# Optional MODIS STAC. Leave empty unless you configure a real MODIS-capable STAC endpoint.
WEA_STAC_MODIS_API_URL=
WEA_STAC_MODIS_COLLECTIONS=

# CDSE credentials are read only by the backend. Do not expose these to Vite/frontend env.
# BA300 OData Product Download uses CDSE_USERNAME/CDSE_PASSWORD with client_id=cdse-public.
# Sentinel Hub sh-* OAuth clients can authenticate but are not accepted by this OData download endpoint.
CDSE_USERNAME=
CDSE_PASSWORD=
CDSE_CLIENT_ID=cdse-public
CDSE_CLIENT_SECRET=
BA300_AUTO_SYNC=false
BA300_SOURCE_MODE=auto
BA300_STAC_COLLECTION=clms_ba_global_300m_monthly_v4_cog
BA300_BYOC_COLLECTION_ID=b8b617c6-182f-427e-a86c-23fc36ac6098
CDS_API_URL=
CAMS_API_URL=

# Used in generated Markdown reports and MapLibre image-source URLs.
# Keep this pointed at the backend API that the browser can reach.
WEA_API_PUBLIC_BASE=http://localhost:8000/api

# Optical imagery map rendering
# tiler = return MapLibre raster-tile URLs served by the local custom composite tiler
# preview = legacy single-image overlay served by the backend preview endpoint
WEA_IMAGERY_RENDER_MODE=tiler
WEA_TILER_PUBLIC_BASE=http://localhost:8001

# Internal tiler URL used by the backend container for PDF/report imagery fetches.
WEA_TILER_INTERNAL_BASE=http://tiler:8000

# Workflow-skill directory inside Docker backend container.
WEA_WORKFLOW_SKILLS_DIR=/app/workflow_skills

# Runtime workflow routing
# rule_based = deterministic message-to-workflow selector
WEA_AGENT_MODE=rule_based

# Tiler cache directory inside Docker tiler container.
WEA_TILER_CACHE_DIR=/cache/wea-tiler
